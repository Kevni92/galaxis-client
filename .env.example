# Konfigurierbare Basis-URL der Galaxis-REST-API.
# Leer lassen für server-relative Aufrufe (OpenAPI-Vertrag: servers: "/").
# Im lokalen Vite-Entwicklungsserver werden /health und /api über den Proxy
# an diesen separat laufenden Server weitergeleitet.
VITE_API_BASE_URL=
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:3000
